#!/usr/bin/env bash

# T2.2 (F4): strict mode for the entire engine. Tactical `|| true` is applied
# ONLY to documented cosmetic Hyprland IPC (hyprctl keyword/dispatch) and
# notify-send calls — NEVER on xfreerdp3, flock, jq, file tests, or any
# security-relevant call (per engine-robustness-delta R2 mitigation).
set -euo pipefail

# multi-peer-race (F-G fix part 1): become a session leader so the EXIT trap
# can `kill -- -$$` to reap child processes (xfreerdp3).
#
# CRITICAL: standard `setpgid 0 0` is a bash-builtin on some distros but an
# external util-linux binary on Arch (and possibly others), where it takes
# completely different args ("run a program in a new process group"). The
# previous form `setpgid 0 0 || true` SILENTLY FAILED via `|| true`, leaving
# the engine in its parent's process group — `kill -- -$$` would then kill
# the parent's whole group (e.g. user's interactive shell). Caught by the
# behavioral coverage follow-up to multi-peer-race.
#
# The portable idiom is `exec setsid --wait`: setsid creates a NEW session
# (which is also a new process group) with the calling process as leader,
# and re-execs this script. `--wait` makes setsid propagate the child's
# exit code back. PID is preserved across the re-exec, so `$$` remains the
# engine's PID == PGID == SID.
#
# Guard via env var to avoid infinite re-exec loop.
if [ -z "${_RDP_SESSION_ESTABLISHED:-}" ]; then
    _RDP_SESSION_ESTABLISHED=1 exec setsid --wait "$0" "$@" || exit $?
fi

# --- OPTIONAL FLAGS: -v | --no-audio | --single-mon | --multi-mon [<profile>] ---
# Strip all optional flags from argv in a single pass, BEFORE --help and every
# other arg-consuming block.
#   -v/--verbose  -> VERBOSE=1 (lib log_event tees to stderr)
#   --no-audio    -> NO_AUDIO=1 (force SOUND_FLAGS empty)
#   --single-mon  -> MONITOR_MODE_OVERRIDE=single (force single-monitor fullscreen)
#   --multi-mon    -> MONITOR_MODE_OVERRIDE=multi  (force multi-monitor)
# Note: under Hyprland/XWayland a single xfreerdp3 window cannot span physical
# monitors, so /multimon renders all remote monitors into one cramped window;
# single mode (+f) fullscreens one remote monitor instead. The mode is also
# settable per-profile via MONITOR_MODE (multi [default] | single).
VERBOSE=0
NO_AUDIO=0
MONITOR_MODE_OVERRIDE=""
_new_args=()
for _a in "$@"; do
    case "$_a" in
        -v|--verbose)  VERBOSE=1 ;;
        --no-audio)    NO_AUDIO=1 ;;
        --single-mon)  MONITOR_MODE_OVERRIDE=single ;;
        --multi-mon)    MONITOR_MODE_OVERRIDE=multi ;;
        *)             _new_args+=("$_a") ;;
    esac
done
set -- "${_new_args[@]}"
unset _a _new_args

# --- MODO AYUDA: rdp-connect --help / -h ---
# MUST be the FIRST arg-handling block. Runs BEFORE require_cmd (F6) AND before
# the lib source / mkdir setup so `--help` is a pure documentation path that
# works in any HOME (including throwaway HOME from `make smoke` and CI probes).
# Standard Unix convention: `--help` exits 0 with no side effects.
# Previously this block sat at line 25, AFTER `mkdir -p` + `source "$LIB_FILE"`
# at lines 15-19, which caused `make smoke` (HOME=$(mktemp -d)) to fail at the
# source step before --help could fire. See verify-report-pr1 W-5.
if [ "${1:-}" == "--help" ] || [ "${1:-}" == "-h" ]; then
    cat << 'HELP_EOF'
rdp-connect — RDP connection framework for Hyprland/Wayland (xfreerdp3)

Usage:
  rdp-connect                    Open graphical selector (wofi/rofi)
  rdp-connect <profile>          Direct connection to a profile
  rdp-connect --new <name>       Create a new profile from template
  rdp-connect --log <profile>    Tail the profile's audit log
  rdp-connect -v <profile>       Verbose: tee milestones + xfreerdp3 output to stderr
  rdp-connect --no-audio <profile>  Disable audio redirect (leave sound on remote)
  rdp-connect --single-mon <profile>  Single-monitor fullscreen (MONITOR_ID picks which)
  rdp-connect --multi-mon <profile>    Multi-monitor (default; cramped window under Hyprland)
  rdp-connect --help | -h        Show this help message

Profiles:  ~/.config/rdp/profiles/*.env
Logs:      ~/.local/state/rdp/<profile>.log
Lockfile:  ${XDG_RUNTIME_DIR:-/tmp}/rdp-<profile>-<uid>.pid
HELP_EOF
    exit 0
fi

PROFILES_DIR="$HOME/.config/rdp/profiles"
I18N_DIR="$HOME/.config/rdp/i18n"
LOG_DIR="$HOME/.local/state/rdp"
SHARE_DIR="$HOME/Compartido"
LIB_FILE="$HOME/.local/lib/rdp/rdp-common.bash"

mkdir -p "$LOG_DIR" "$SHARE_DIR" "$PROFILES_DIR" "$I18N_DIR"

# --- CARGA DE LA BIBLIOTECA DE FUNCIONES PURAS (F3 parser, F5 PID path, F1 hidpi, F6/F8 helpers) ---
# shellcheck source=/home/hbuddenberg/.local/lib/rdp/rdp-common.bash
source "$LIB_FILE"

# --- PREFLIGHT (F6 + F7): every external binary present + xfreerdp3 build gate ---
# F6: require_cmd exits 127 if a binary is missing. Done BEFORE any profile is
# loaded so a missing dep never reaches a credential-adjacent code path. The
# wofi|rofi launcher OR-check is deferred to selector mode (only needed there).
require_cmd xfreerdp3 freerdp3
require_cmd hyprctl hyprland
require_cmd jq jq
require_cmd notify-send libnotify
require_cmd flock util-linux

# F7: the credential pipe is on the password path. A build without /from-stdin
# support would either leak the password via /p: on the command line or hang
# forever reading stdin. The feature gate MUST fail loudly — NEVER silently
# fall back to /p:.
if ! xfreerdp3 /help 2>&1 | grep -q from-stdin; then
    echo "ERROR: xfreerdp3 build does not support /from-stdin:force." >&2
    echo "       Install a FreeRDP3 build with stdin credential support." >&2
    exit 1
fi

# --- DETECCIÓN Y CARGA DE IDIOMA (i18n) ---
# Cargado a través del parser endurecido (F2: no `source`). El modo `i18n`
# acepta solo claves con prefijo MSG_*; cualquier otra clave (p.ej. PATH=)
# aborta el motor — un archivo i18n hostil es un evento de seguridad, no un
# fallback silencioso.
load_language() {
    local target_lang="${1:-${LANG:-es}}"
    target_lang="${target_lang:0:2}"
    local lang_file="$I18N_DIR/${target_lang}.env"
    [ -f "$lang_file" ] || lang_file="$I18N_DIR/es.env"
    parse_env_safe "$lang_file" i18n || {
        notify-send -u critical "RDP Error" "Diccionario de idioma inválido ($lang_file). Ver consola." 2>/dev/null || true
        exit 1
    }
}
load_language

# --- PARSER SEGURO DE CONFIGURACIÓN (Previene inyección de código Bash) ---
# La implementación vive en lib/rdp-common.bash (sourced arriba como LIB_FILE).
# Permite allowlist estricto (HOST, USER_RDP, PASS_RDP, DOMAIN, VPN_CHECK,
# PREFERRED_WS, LANG_OVERRIDE) y normaliza comillas/comentarios. Cualquier
# clave fuera de la allowlist aborta el motor.

# --- MODO VISOR DE LOGS: rdp-connect --log <perfil> ---
if [ "${1:-}" == "--log" ] || [ "${1:-}" == "-l" ]; then
    LOG_PROFILE="${2:-}"
    [ -z "$LOG_PROFILE" ] && { echo "$MSG_LOG_USAGE"; exit 1; }
    TARGET_LOG="$LOG_DIR/${LOG_PROFILE}.log"
    [ ! -f "$TARGET_LOG" ] && { printf "$MSG_LOG_NO_FILE\n" "$LOG_PROFILE"; exit 1; }
    echo "=== Viendo log en vivo de '$LOG_PROFILE' ($TARGET_LOG) ==="
    tail -n 30 -f "$TARGET_LOG"
    exit 0
fi

# --- MODO CREADOR: rdp-connect --new <perfil> ---
if [ "${1:-}" == "--new" ]; then
    NEW_PROFILE="${2:-}"
    [ -z "$NEW_PROFILE" ] && { echo "$MSG_NEW_USAGE"; exit 1; }

    TARGET_FILE="$PROFILES_DIR/${NEW_PROFILE}.env"
    [ -f "$TARGET_FILE" ] && { printf "$MSG_NEW_EXISTS\n" "$NEW_PROFILE"; exit 1; }

    cp "$HOME/.config/rdp/template.env" "$TARGET_FILE"
    chmod 600 "$TARGET_FILE"
    printf "$MSG_NEW_CREATED\n" "$TARGET_FILE"

    SYSTEM_EDITOR="${EDITOR:-${VISUAL}}"
    if [ -z "$SYSTEM_EDITOR" ]; then
        for ed in nvim vim nano vi micro; do
            if command -v "$ed" &>/dev/null; then
                SYSTEM_EDITOR="$ed"
                break
            fi
        done
    fi

    # Si se invoca desde GUI sin TTY, lanzar dentro de emulador de terminal
    if [ ! -t 0 ]; then
        TERM_EMU="${TERMINAL:-kitty}"
        $TERM_EMU -e "$SYSTEM_EDITOR" "$TARGET_FILE" &
    else
        "$SYSTEM_EDITOR" "$TARGET_FILE"
    fi
    exit 0
fi

# --- MODO SELECTOR (Wofi / Rofi) ---
PROFILE="${1:-}"
if [ -z "$PROFILE" ]; then
    # F6 launcher OR-check: wofi OR rofi must be present in selector mode.
    # This check is deferred to here (not in the startup preflight) because the
    # launcher is only needed when no profile argument is given — a direct
    # `rdp-connect <profile>` never invokes the selector.
    if ! command -v wofi &>/dev/null && ! command -v rofi &>/dev/null; then
        echo "missing required command: wofi or rofi (install one via your package manager)" >&2
        exit 127
    fi
    if command -v wofi &>/dev/null; then
        PROFILE=$(ls "$PROFILES_DIR" | sed 's/\.env$//' | wofi --dmenu --prompt "$MSG_PROMPT_SELECT" || true)
    elif command -v rofi &>/dev/null; then
        PROFILE=$(ls "$PROFILES_DIR" | sed 's/\.env$//' | rofi -dmenu -p "$MSG_PROMPT_SELECT" || true)
    fi
fi
[ -z "$PROFILE" ] && exit 0

ENV_FILE="$PROFILES_DIR/${PROFILE}.env"
[ ! -f "$ENV_FILE" ] && { notify-send -u critical "RDP Error" "$(printf "$MSG_ERR_NO_PROFILE" "$PROFILE")" 2>/dev/null || true; exit 1; }

# Pre-initialize all allowlisted profile keys to empty so set -u never aborts
# on an optional key the user omitted from their profile. HOST/USER_RDP/PASS_RDP
# remain effectively required — an empty value produces a clear xfreerdp3 error
# at connection time (better UX than a set -u "unbound variable" crash).
HOST="" USER_RDP="" PASS_RDP="" DOMAIN=""
VPN_CHECK="" PREFERRED_WS="" LANG_OVERRIDE=""

# Carga segura de variables — abort on parser failure (F3 security boundary).
# parse_env_safe prints 'parse_env_safe: <file>:<line>: <reason>' to stderr;
# the engine surfaces via notify-send (best-effort) and exits 1 so a malformed
# or hostile profile can NEVER reach xfreerdp3.
parse_env_safe "$ENV_FILE" profile || {
    notify-send -u critical "RDP Error" "Perfil '$PROFILE' inválido. Ver consola." 2>/dev/null || true
    exit 1
}

# T2.1: Trim leading/trailing whitespace from network-identifier fields so
# `VPN_CHECK=" "`, `VPN_CHECK="  10.8.0.1  "`, or `HOST="  server  "` (common
# copy-paste / editor mistakes) don't silently corrupt the TCP probes.
# PASS_RDP is intentionally NOT trimmed — passwords MAY legitimately contain
# leading/trailing spaces. USER_RDP also left untouched for the same reason.
#
# T2.6 (engine-security-delta R1): the trim allowlist (5 trimmed + 2 excluded)
# MUST live in exactly one place — lib/rdp-common.bash::trim_profile_fields —
# so drift between consumers is impossible. The inline parameter-expansion
# idiom was lifted verbatim into the lib fn; the engine now delegates so the
# bats suite tests the REAL trim, not a reimplementation.
trim_profile_fields

[ -n "${LANG_OVERRIDE:-}" ] && load_language "$LANG_OVERRIDE"

WM_CLASS="rdp-${PROFILE}"
LOG_FILE="$LOG_DIR/${PROFILE}.log"
# T1.4 (F5): uid-private PID path under XDG_RUNTIME_DIR (or /tmp fallback with
# uid suffix). Eliminates the world-writable /tmp/rdp-<profile>.pid symlink/DoS
# vector — two users on the same host can no longer collide or interfere.
PID_FILE="$(compute_pid_path "$PROFILE")"
START_TIME=$(date +%s)

# log_event lives in lib/rdp-common.bash (extracted for unit-testable verbose
# tee). It reads LOG_FILE + VERBOSE globals at call time; both are set by here.

# --- SINGLE INSTANCE GUARD (Flock exclusivo por perfil) ---
# flock is process-bound: a crashed peer's lock is released by the kernel,
# so our flock -n succeeds and we overwrite the stale PID content below
# (stale-lock reclamation is automatic). A live peer holds the fd → flock -n
# fails → we focus the existing window and exit 0 (peer-honored).
#
# _LOCK_ACQUIRED (multi-peer race fix from T1.4 discovery): only the lock owner
# unlinks the PID file in the EXIT trap. A peer that failed flock -n does NOT
# own the lock — unlinking the file would break the first instance's per-inode
# flock and allow a third instance to bypass it.
_LOCK_ACQUIRED=false
exec 200>"$PID_FILE"
if ! flock -n 200; then
    # shellcheck disable=SC2188  # $(<file) is the bash no-fork file-read idiom; 2>/dev/null + || true handle missing/unreadable files (peer holds lock but file content may be empty if peer crashed before writing)
    _peer=$(<"$PID_FILE" 2>/dev/null || true)
    log_event "WARN" "Instancia activa pid=${_peer:-?} detectada. Enfocando ventana..."
    notify-send -i display "RDP $PROFILE" "$MSG_ALREADY_ACTIVE" || true
    # Hyprland 0.55+: focus the peer's existing window via the Lua dispatcher
    # (`hyprctl dispatch '<lua>'`). The legacy `focuswindow class:...` form was
    # rejected by the new parser. Window already exists in this path.
    hyprctl dispatch "hl.dsp.focus({ window = \"class:$WM_CLASS\" })" &>/dev/null || true
    exit 0
fi
_LOCK_ACQUIRED=true
echo "$$" >&200

# --- CLEANUP TRAP & DIAGNÓSTICO ---
cleanup() {
    EXIT_CODE=$?
    # multi-peer-race (F-G fix part 2): reap the engine's process group BEFORE
    # any logging. Children (xfreerdp3) get killed first so they don't outlive
    # the engine. `kill -- -$$` sends to all processes in pgid == $$ (the
    # engine is the leader thanks to setpgid at startup). `--` guards against
    # $$ looking like a flag (e.g. SIGHUP if -1). `2>/dev/null || true` because
    # kill on already-dead processes returns non-zero.
    kill -- -$$ 2>/dev/null || true
    END_TIME=$(date +%s)
    DURATION=$((END_TIME - START_TIME))

    if [ $EXIT_CODE -ne 0 ]; then
        # F9 / T2.5 (Bug B) context: scope the error search to the CURRENT
        # session only. The SESSION_START marker (pid=$$) written as the first
        # log line of this session bounds the scan — without it, a `tail -n N`
        # would surface stale ERROR lines from PREVIOUS sessions in the same
        # per-profile LOG_FILE as if they were this session's failure cause
        # (e.g. an old "VPN requerida inalcanzable" from days ago reported
        # as the cause of a fresh parse/preflight failure).
        #
        # The pid= suffix on the marker makes it unique to THIS process so
        # concurrent sessions on the same profile (impossible under flock but
        # defensive) cannot cross-pollinate. PID prefix safety (222 vs 2222)
        # is enforced inside the fn via the `([^0-9]|$)` awk anchor.
        #
        # T3.1: the file-existence guard + awk extractor were lifted verbatim
        # into lib/rdp-common.bash::extract_session_error (pure text
        # transformation, no side effects — safe to unit-test). The engine's
        # old `[ -n "${START_TIME:-}" ]` defensive guard is dropped: the trap
        # registers AFTER START_TIME is assigned (L192 → trap L272), so the
        # guard is statically true at every cleanup invocation. If no marker
        # for our PID exists (e.g. trap fired before the first log_event
        # call), the fn returns empty — the caller falls back to the generic
        # 'Ver log en $LOG_FILE' message, which is correct.
        LAST_ERROR="$(extract_session_error "$LOG_FILE" "$$")"
        log_event "ERROR" "Sesión finalizada con error (Código $EXIT_CODE). Duración: ${DURATION}s."
        log_event "ERROR" "Causa reportada: ${LAST_ERROR:-Error no especificado}"
        notify-send -u critical -i network-error "RDP $PROFILE Error" "${LAST_ERROR:-Ver log en $LOG_FILE}" || true
    else
        log_event "INFO" "Sesión finalizada correctamente. Duración total: ${DURATION}s."
        notify-send -i display-off "RDP $PROFILE" "$MSG_SESSION_ENDED" || true
    fi
    # multi-peer-race (F-G fix part 3): do NOT unlink $PID_FILE.
    # The previous code (baseline-hardening T1.4 + T2.2 _LOCK_ACQUIRED guard)
    # closed the ORIGINAL T1.4 race (peer-branch triggering cleanup), but
    # the exploration for this change found a DIFFERENT race (R7): when a
    # signal (SIGTERM, SIGINT) fires the EXIT trap while fd 200 still holds
    # the inode lock, unlinking the path leaves the inode anonymous but
    # locked. A third process opening $PID_FILE creates a NEW inode at the
    # same path; its flock -n succeeds on the new inode → two concurrent
    # xfreerdp3 sessions against the same profile. Reproduced empirically
    # in openspec/changes/multi-peer-race/explore.md.
    #
    # Fix: never unlink. Kernel releases flock on process death; the path
    # persists benignly in $XDG_RUNTIME_DIR; next start's `exec 200>` +
    # `flock -n` reclaims a stale lockfile automatically.
    #
    # Spec amendment: openspec/specs/instance-locking/spec.md will be
    # updated at /sdd-archive to invert the "EXIT trap MUST remove" rule.
    # The canonical amendment is deferred to archive per SDD convention.
    #
    # `_LOCK_ACQUIRED` is kept for diagnostic purposes (logging) but no
    # longer gates any file operation.
    :
}
trap cleanup EXIT

# T2.5 (Bug B): SESSION_START marker is the FIRST log line of this session.
# cleanup() uses it to scope its error diagnostic to the CURRENT session only
# — preventing stale ERROR lines from previous sessions (same per-profile
# LOG_FILE) from being reported as this session's failure cause. The pid=
# suffix makes the marker unique to this PID so concurrent sessions on the
# same profile (impossible under flock but defensive) can't cross-pollinate.
# This MUST be the first log_event call so any later failure (VPN check, host
# check, xfreerdp3) has a bounded "current session" window to scan.
log_event "SESSION_START" "pid=$$ profile=$PROFILE"
log_event "INFO" "=================== INICIO DE SESIÓN RDP ==================="
log_event "INFO" "Perfil: $PROFILE | Host: $HOST | Usuario: $USER_RDP"

# --- PRE-FLIGHT CHECK (Vía socket nativo /dev/tcp) ---
# T2.6: VPN_CHECK is trimmed right after parse_env_safe (line ~167), so "  " or
# "  host  " in the profile becomes "" or "host" respectively. The guard below
# then correctly treats empty (no VPN configured) as SKIP, and a real host as
# ENTER. Without the trim, "  " passed `-n` and produced "VPN requerida ( )
# inalcanzable" on every invocation.
if [ -n "${VPN_CHECK:-}" ]; then
    log_event "INFO" "Verificando VPN ($VPN_CHECK)..."
    if ! timeout 2 bash -c "</dev/tcp/$VPN_CHECK/3389" &>/dev/null; then
        ERR_VPN=$(printf "$MSG_ERR_VPN" "$VPN_CHECK")
        log_event "ERROR" "VPN requerida ($VPN_CHECK) inalcanzable. Abortando."
        notify-send -u critical -i network-vpn "RDP Error" "$ERR_VPN" || true
        exit 1
    fi
fi

log_event "INFO" "Verificando disponibilidad de puerto 3389 en $HOST..."
if ! timeout 2 bash -c "</dev/tcp/$HOST/3389" &>/dev/null; then
    ERR_HOST=$(printf "$MSG_ERR_HOST_UNREACHABLE" "$HOST")
    log_event "ERROR" "Servidor $HOST:3389 inalcanzable. Abortando."
    notify-send -u critical -i network-error "RDP Error" "$ERR_HOST" || true
    exit 1
fi
log_event "INFO" "Puerto 3389 en $HOST respondiendo correctamente."

# --- HIDPI AUTO-SCALING (F1: jq-native, no bc/python3) ---
# compute_dpi_flags lives in lib/rdp-common.bash. It sets DPI_FLAGS[] (array),
# IS_HIDPI, and SCALE_PCT via a single `hyprctl monitors -j | jq` call.
# Null / missing / non-numeric scale → WARN + 100% fallback (session proceeds).
compute_dpi_flags

# --- MULTI-MONITOR Y REGLAS DE HYPRLAND ---
MONITORS=$(hyprctl monitors -j | jq -r '.[].id' | paste -sd, -)
MON_COUNT=$(hyprctl monitors -j | jq '. | length')
# F8: MON_FLAGS is an array, not a string. build_mon_flags (in lib) sets
# MON_FLAGS=("/multimon" "/monitors:<ids>") or ("/f"). Expanded at the
# xfreerdp3 invocation site below as "${MON_FLAGS[@]}".
#
# DO NOT use "${arr[@]-}" here or for DPI_FLAGS. Bash gotcha: with a DECLARED-
# EMPTY array, "${arr[@]-}" yields a single empty-string token (argc=1), not
# zero tokens. DPI_FLAGS is empty when scale==1.0, so the old "${DPI_FLAGS[@]-}"
# form injected a phantom '' into argv that xfreerdp3 3.30.0 rejects as
# "Unsupported command line syntax". "${arr[@]}" (no `-`) is correct: bash 4.4+
# does not trip set -u on an empty array. See tests/freerdp3-flags.bats.
# --- MONITOR MODE (MONITOR_MODE profile key + --single-mon/--multi-mon CLI) ---
# Effective mode: CLI override wins, else profile MONITOR_MODE, else multi.
# Under Hyprland/XWayland, /multimon renders all remote monitors into one
# window (can't span physical outputs); single mode fullscreens one remote
# monitor (/monitors:<id> +f). MONITOR_ID picks the remote monitor in single
# mode (default 0). MON_FLAGS is an array; expanded with "${MON_FLAGS[@]}"
# (zero args when empty — the correct form, NO `-`).
MON_FLAGS=()
case "${MONITOR_MODE_OVERRIDE:-${MONITOR_MODE:-multi}}" in
    single)
        _EFF_MODE=single
        # Query the selected client monitor's native resolution and ask FreeRDP
        # to render the remote desktop at that size, then fullscreen. Without
        # /size, FreeRDP negotiates a small default (HD on a 2K screen).
        _mon_res=$(hyprctl monitors -j 2>/dev/null | jq -r --argjson id "${MONITOR_ID:-0}" '.[] | select(.id==$id) | "\(.width)x\(.height)"' 2>/dev/null || true)
        if [ -n "${_mon_res:-}" ]; then
            MON_FLAGS=("/size:$_mon_res" "+f")
        else
            MON_FLAGS=("+f")
        fi
        unset _mon_res
        log_event "INFO" "Modo single-monitor: monitor client ${MONITOR_ID:-0} -> /size +f fullscreen."
        ;;
    multi|*)
        _EFF_MODE=multi
        build_mon_flags "$MON_COUNT" "$MONITORS"
        log_event "INFO" "Pantallas detectadas en Hyprland: $MON_COUNT (IDs: $MONITORS)."
        ;;
esac

# --- AUDIO TOGGLE (AUDIO_REDIRECT profile key + --no-audio CLI override) ---
# Three modes, matching mstsc "Remote Audio Playback":
#   AUDIO_REDIRECT=1 (default) -> /sound + /microphone  ("Play on this computer" = redirect to client)
#   AUDIO_REDIRECT=0           -> /audio-mode:1         ("Play on remote computer" = server's local speakers)
#   --no-audio (CLI override)  -> (empty)               ("Do not play" = no audio at all)
#
# WARNING: xfreerdp3 /? MISLABELS /audio-mode. The help claims :2 is "server",
# but the source (settings.h) + empirical RDP-flag verification prove the real
# mapping: :0=redirect, :1=leave-on-server, :2=DISABLE. /audio-mode:1 sets
# INFO_REMOTECONSOLEAUDIO in the Client Info Packet (the "play on remote
# console" signal); /audio-mode:2 does NOT (it disables audio). Use :1 for
# server playback. See tests/audio-toggle.bats for the regression.
#
# Built as an array, expanded with "${SOUND_FLAGS[@]}" (zero args when empty —
# the CORRECT empty-array form; the "-default" gotcha that broke DPI_FLAGS
# must NOT come back here).
SOUND_FLAGS=()
if [ "${NO_AUDIO:-0}" = "1" ]; then
    : # --no-audio: no audio at all
elif [ "${AUDIO_REDIRECT:-1}" = "1" ]; then
    SOUND_FLAGS=("/sound:sys:pulse,latency:20" "/microphone:sys:pulse")
else
    # AUDIO_REDIRECT=0: play on the REMOTE server (xfreerdp3 /audio-mode:1 =
    # mstsc "Play on remote computer"; sets INFO_REMOTECONSOLEAUDIO). NOT empty
    # — empty produced the "no audio devices" bug (RDP session had no audio).
    SOUND_FLAGS=("/audio-mode:1")
fi

# --- BACKGROUND WINDOW MANAGEMENT (Hyprland 0.55+ Lua dispatcher API) ---
# The new API is action-based (the window must already exist), but xfreerdp3
# hasn't created it yet. Spawn a background subshell that polls for the window
# by class, then: moves it to PREFERRED_WS, focuses it, and (single mode)
# fullscreens it. Runs concurrently with the xfreerdp3 pipeline below.
# `hyprctl dispatch '<lua>'` executes the dispatcher; `class:$WM_CLASS` is the
# selector. See tests/hyprland-api.bats + wiki/Using-hyprctl.
(
    # Close the lock fd so this background subshell does NOT independently hold
    # the flock — only the main engine process holds it. Otherwise the lock
    # would persist as long as this helper (or any other child) is alive, even
    # after the engine exits (the lock-leak root cause).
    exec 200>&-
    _tries=0
    while [ "$_tries" -lt 30 ]; do
        if hyprctl clients -j 2>/dev/null | jq -e --arg c "$WM_CLASS" 'any(.[]; .class==$c)' >/dev/null 2>&1; then
            break
        fi
        sleep 0.2
        _tries=$((_tries+1))
    done
    if [ -n "${PREFERRED_WS:-}" ]; then
        hyprctl dispatch "hl.dsp.window.move({ workspace = \"$PREFERRED_WS\", window = \"class:$WM_CLASS\" })" &>/dev/null || true
        log_event "INFO" "Ventana $WM_CLASS movida al Workspace $PREFERRED_WS." 2>/dev/null || true
    fi
    hyprctl dispatch "hl.dsp.focus({ window = \"class:$WM_CLASS\" })" &>/dev/null || true
    if [ "${_EFF_MODE:-multi}" = "single" ]; then
        hyprctl dispatch "hl.dsp.window.fullscreen({ mode = \"fullscreen\", action = \"set\", window = \"class:$WM_CLASS\" })" &>/dev/null || true
        log_event "INFO" "Ventana $WM_CLASS fullscreen (single-mon)." 2>/dev/null || true
    fi
) &

export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
export LIBVA_DRIVER_NAME=iHD

notify-send -i display "RDP Framework" "$(printf "$MSG_CONNECTING" "$PROFILE" "$MON_COUNT")" || true

log_event "INFO" "Lanzando xfreerdp3 mediante STDIN seguro..."

# --- EJECUCIÓN (Contraseña oculta de la tabla de procesos ps aux) ---
# xfreerdp3 runs inside a subshell that CLOSES fd 200 (the lock fd), so
# xfreerdp3 and any process it spawns do NOT inherit the flock. Only the main
# engine process holds the lock → it releases the instant the engine exits.
# Output goes to a timestamping logger via process substitution (> >(...)).
# Unlike a pipeline (`xfreerdp3 | while`), the engine here waits for the
# { ... } group (i.e. xfreerdp3 itself) to finish — NOT for the pipe to reach
# EOF — so the engine exits as soon as xfreerdp3 dies, even if orphaned child
# processes momentarily hold the output pipe open (the lock-leak root cause).
echo "$PASS_RDP" | { exec 200>&-; xfreerdp3 \
  /v:"$HOST" \
  ${DOMAIN:+/d:"$DOMAIN"} \
  /u:"$USER_RDP" \
  /from-stdin:force \
  /wm-class:"$WM_CLASS" \
  /sec:nla \
  /cert:tofu \
  "${MON_FLAGS[@]}" \
  "${DPI_FLAGS[@]}" \
  +grab-keyboard \
  /async-update \
  /mouse-motion \
  "${SOUND_FLAGS[@]}" \
  +clipboard \
  +smartcard \
  +printer \
  /drive:compartido,"$SHARE_DIR" \
  /network:auto \
  /gfx:avc444 \
  +fonts \
  +aero \
  +auto-reconnect \
  /auto-reconnect-max-retries:10; } > >(while IFS= read -r _rdp_line; do
    _rdp_ts="[$(date '+%Y-%m-%d %H:%M:%S')] [RDP] $_rdp_line"
    printf '%s\n' "$_rdp_ts" >> "$LOG_FILE"
    if [ "${VERBOSE:-0}" = "1" ]; then
        printf '%s\n' "$_rdp_ts" >&2
    fi
done) 2>&1
